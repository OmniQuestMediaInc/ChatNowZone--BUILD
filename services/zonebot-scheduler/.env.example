# .env.example — ZoneBot Scheduler (Zoey)
# WO-002: Copy to .env and fill in values before starting the service.
# NEVER commit a populated .env file to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://cnz_user:CHANGE_ME@localhost:5432/cnz_db

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Jurisdiction code used when none is set on a StaffMember record.
HCZ_DEFAULT_JURISDICTION=ON

# ── Cash Incentives ───────────────────────────────────────────────────────────
# Spin-wheel incentive amount in CAD cents (5000 = $50.00).
HCZ_INCENTIVE_SPIN_CAD_CENTS=5000

# ── Fatigue ───────────────────────────────────────────────────────────────────
# Fatigue score threshold above which a warning flag is raised (0-100).
HCZ_FATIGUE_WARN_THRESHOLD=70
# Fatigue score threshold above which scheduling is blocked (0-100).
HCZ_FATIGUE_BLOCK_THRESHOLD=90

# ── Payroll Export ────────────────────────────────────────────────────────────
# Default hourly rate in CAD cents — used in budget forecasting fallback.
HCZ_DEFAULT_HOURLY_RATE_CAD_CENTS=1800

# ── NestJS ────────────────────────────────────────────────────────────────────
PORT=3010
NODE_ENV=development
