# SenSync™ — Environment Variables

# NATS broker URL (required)
NATS_URL=nats://localhost:4222

# PostgreSQL connection string (required — for HeartSyncTierConfig reads)
DATABASE_URL=postgresql://user:password@localhost:5432/chatNowZone

# Redis (required if used by parent app)
REDIS_HOST=localhost
REDIS_PORT=6379

# HeartSync feature flags (optional — can also be set via DB tier config)
# Set to 'true' to enable HeartSync for VIP tier on startup (before DB seed)
HEARTSYNC_VIP_ENABLED=false
HEARTSYNC_VIP_SILVER_ENABLED=false
HEARTSYNC_VIP_GOLD_ENABLED=true
HEARTSYNC_VIP_PLATINUM_ENABLED=true
HEARTSYNC_VIP_DIAMOND_ENABLED=true
