# SenSync™ — Environment Variables

# NATS broker URL (required)
NATS_URL=nats://localhost:4222

# PostgreSQL connection string (required — for SenSyncTierConfig reads)
DATABASE_URL=postgresql://user:password@localhost:5432/chatNowZone

# Redis (required if used by parent app)
REDIS_HOST=localhost
REDIS_PORT=6379

# SenSync™ feature flags (optional — can also be set via DB tier config)
# Set to 'true' to enable SenSync™ for VIP tier on startup (before DB seed)
SENSYNC_VIP_ENABLED=false
SENSYNC_VIP_SILVER_ENABLED=false
SENSYNC_VIP_GOLD_ENABLED=true
SENSYNC_VIP_PLATINUM_ENABLED=true
SENSYNC_VIP_DIAMOND_ENABLED=true
