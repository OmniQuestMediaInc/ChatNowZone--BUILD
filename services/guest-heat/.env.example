# Guest-Heat — Environment Variables

# NATS broker URL (required)
NATS_URL=nats://localhost:4222

# PostgreSQL connection string (required — WhaleProfile + Gemstone persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/chatNowZone

# Redis (required if used by parent app)
REDIS_HOST=localhost
REDIS_PORT=6379

# Whale scoring — optional overrides (default values shown)
# GUEST_HEAT_WHALE_SCORE_CEILING=5000

# Offer TTLs (in minutes)
# GUEST_HEAT_OFFER_TTL_SPENDING_PATTERN_MIN=30
# GUEST_HEAT_OFFER_TTL_GEO_PRICE_MIN=60
# GUEST_HEAT_OFFER_TTL_LOYALTY_REWARD_MIN=1440

# Dual Flame Pulse cooldown (milliseconds)
# GUEST_HEAT_DUAL_FLAME_COOLDOWN_MS=60000

# Performance timer thresholds (minutes)
# GUEST_HEAT_PERF_TIMER_YELLOW_MIN=20
# GUEST_HEAT_PERF_TIMER_RED_MIN=40
